{
    "version": 3,
    "endpoints": [
        {
            "endpoint": "/login-service/auth/v1/signup",
            "method": "POST",
            "backend": [
                {
                    "url_pattern": "/login-service/auth/v1/signup",
                    "method": "POST",
                    "host": ["http://login-service:8000"]
                }
            ]
        },

        {
            "endpoint": "/login-service/auth/v1/signin",
            "method": "POST",
            "backend": [
                {
                    "url_pattern": "/login-service/auth/v1/signin",
                    "method": "POST",
                    "host": ["http://login-service:8000"]
                }
            ]
        },

        {
            "endpoint": "/scraping-service/v1/get-login-details",
            "timeout": "180s",
            "method": "POST",
            "input_headers": [
                "Authorization"
            ],
            "extra_config": {
                "auth/validator": {
                    "alg": "HS512",
                    "jwk_local_path": "./jwk.txt", 
                    "audience": ["scraping", "notification"],
                    "operation_debug": true,
                    "disable_jwk_security": true,
                    "cache": false
                }
            },
            "backend": [
                {
                    "url_pattern": "/scraping-service/v1/get-login-details",
                    "method": "POST",
                    "host": ["http://scraping-service:8001"]
                }
            ]
        },

        {
            "endpoint": "/scraping-service/v1/webscrape-timetable",
            "timeout": "240s",
            "method": "POST",
            "input_headers": [
                "Authorization"
            ],
            "extra_config": {
               "auth/validator": {
                   "alg": "HS512",
                   "jwk_local_path": "./jwk.txt", 
                   "audience": ["scraping", "notification"],
                   "operation_debug": true,
                   "disable_jwk_security": true,
                   "cache": false
               }
            },
           "backend": [
                {
                    "url_pattern": "/scraping-service/v1/webscrape-timetable",
                    "method": "POST",
                    "host": ["http://scraping-service:8001"]
                }
            ]
        },

        {
            "endpoint": "/scraping-service/v1/login-status/{userID}",
            "timeout": "10s",
            "method": "GET",
            "input_headers": [
                "Authorization"
            ],
            "extra_config": {
               "auth/validator": {
                   "alg": "HS512",
                   "jwk_local_path": "./jwk.txt", 
                   "audience": ["scraping", "notification"],
                   "operation_debug": true,
                   "disable_jwk_security": true,
                   "cache": false
               }
            },
           "backend": [
                {
                    "url_pattern": "/scraping-service/v1/login-status/{userID}",
                    "method": "GET",
                    "host": ["http://scraping-service:8001"]
                }
            ]
        }

    ],
    "extra_config": {
        "telemetry/logging": {
            "level": "INFO",
            "prefix": "[API GATEWAY LOGS]",
            "syslog": false,
            "stdout": true
        },

        "security/cors": {
            "allow_origins": [
                "http://localhost:5173"
            ],
            
            "allow_methods": [
                "GET",
                "HEAD",
                "POST",
                "DELETE",
                "OPTIONS"
            ],
            
            "expose_headers": [
                "Content-Length",
                "Content-Type"
            ],

            "allow_headers": [
                "Origin",
                "Authorization",
                "Content-Type"
            ],

            "max_age": "12h",
            "allow_credentials": true,
            "debug": true
        }
    }
}
